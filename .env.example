# Copy this file to .env and fill in real values. Never commit .env.

# --- VPS (DigitalOcean) ---
VPS_HOST=your.vps.ip.here
VPS_USER=root
VPS_PASSWORD=replace-me

# --- Interactive Brokers ---
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=1

# --- Discord webhooks (one per channel) ---
DISCORD_WEBHOOK_TRADE=https://discord.com/api/webhooks/.../...
DISCORD_WEBHOOK_SUMMARY=https://discord.com/api/webhooks/.../...
DISCORD_WEBHOOK_BALANCE=https://discord.com/api/webhooks/.../...
DISCORD_WEBHOOK_PORTFOLIO=https://discord.com/api/webhooks/.../...
DISCORD_WEBHOOK_DAILY_REPORT=https://discord.com/api/webhooks/.../...

# --- Alpaca (backtest data only, optional) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Email (optional) ---
EMAIL_TO=
EMAIL_FROM=
GMAIL_APP_PASSWORD=
